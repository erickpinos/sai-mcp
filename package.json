{
  "name": "sai-mcp",
  "version": "0.1.0",
  "description": "MCP server for the Sai.fun perpetual futures protocol on Nibiru Chain. Exposes the sai-keeper GraphQL API as MCP tools.",
  "type": "module",
  "bin": {
    "sai-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "start:http": "cross-env SAI_HTTP_PORT=3000 node dist/index.js",
    "inspect": "npx @modelcontextprotocol/inspector node dist/index.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "sai",
    "sai.fun",
    "nibiru",
    "perpetuals",
    "defi",
    "graphql"
  ],
  "author": "Erick Pinos <erick@erickpinos.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/erickpinos/sai-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/erickpinos/sai-mcp/issues"
  },
  "homepage": "https://github.com/erickpinos/sai-mcp#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "bech32": "^2.0.0",
    "ethers": "^6.16.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "cross-env": "^7.0.3",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=18"
  }
}
